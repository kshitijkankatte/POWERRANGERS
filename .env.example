# Copy this file to `.env` and fill in secrets.

# Anthropic API Configuration (optional; app has fallbacks)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API Configuration (optional; /api/gemini/enhance will fall back if unset)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
# Used by setup scripts and when running `python main.py`
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# Legacy names (still accepted by scripts)
SERVER_HOST=0.0.0.0
SERVER_PORT=8001

# Database
DATABASE_URL=sqlite:///sahanak.db

# Frontend URL for CORS (currently CORS allows all origins)
FRONTEND_URL=http://localhost:8000
